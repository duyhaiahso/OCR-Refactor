{
  "name": "ocr-metal-core-washing-refactor",
  "version": "0.1.0",
  "private": true,
  "description": "Local desktop refactor for OCR Metal Core Washing.",
  "workspaces": [
    "frontend",
    "backend",
    "electron",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:desktop": "npm run dev -w @ocr/electron",
    "dev:frontend:safe": "powershell -ExecutionPolicy Bypass -File ./scripts/start-frontend-safe.ps1",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=22"
  }
}
